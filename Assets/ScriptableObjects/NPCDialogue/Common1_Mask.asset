  m_Name: Common1_Mask
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogueData
  npcName: "\u0420\u0430\u0431\u043E\u0442\u043D\u0438\u043A"
  dialogueLines:
  - "\u041B\u0438\u043A\u0432\u0438\u0434\u0438\u0440\u0430\u0439 \u0441\u043C\u0435\u0442\u043A\u0430\u0442\u0430
    \u201E\u0425\u0435\u043D\u0434\u0435\u0440\u0441\u044A\u043D\u201C."
  - "\u0427\u0443\u0432\u0430\u043B \u043B\u0438 \u0441\u0438 \u0437\u0430 \u0432\u0438\u0441\u0448\u0438\u044F
    \u043C\u0435\u043D\u0438\u0434\u0436\u043C\u044A\u043D\u0442?"
  - "\u0422\u0440\u044F\u0431\u0432\u0430\u0445\u0430 \u043C\u0438 \u0442\u0435\u0437\u0438
    \u043E\u0442\u0447\u0435\u0442\u0438 \u043E\u0449\u0435 \u0432\u0447\u0435\u0440\u0430."
  - "\u0411\u0438\u043B \u043B\u0438 \u0441\u0438 \u0432 \u0433\u043E\u0440\u043D\u0438\u044F
    \u0440\u0430\u0439\u043E\u043D? \u041E, \u043A\u0430\u043A\u0432\u043E \u0433\u043E\u0432\u043E\u0440\u044F
    \u2014 \u0440\u0430\u0437\u0431\u0438\u0440\u0430 \u0441\u0435, \u0447\u0435
    \u043D\u0435 \u0441\u0438."
  - "\u0429\u0435 \u0441\u0435 \u0432\u0438\u0434\u0438\u043C \u0442\u043E\u0437\u0438
    \u043F\u0435\u0442\u044A\u043A. \u041D\u0430\u043B\u0438 \u0449\u0435 \u043C\u0438
    \u0438\u0437\u043F\u0440\u0430\u0442\u0438\u0448 \u0434\u043E\u043A\u043B\u0430\u0434\u0430
    \u0434\u043E 3 \u0447\u0430\u0441\u0430 \u0434\u043D\u0435\u0441?"
  bubbleDisplayTime: 0
  throwOnLineIndex: -1
