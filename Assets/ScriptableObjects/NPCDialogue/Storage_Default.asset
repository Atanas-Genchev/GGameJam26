    \u043D\u0435 \u0441\u0438 \u0434\u043E\u0431\u0440\u0435 \u0434\u043E\u0448\u044A\u043B."
  - "T\u0443\u043A \u0435 \u0441\u0430\u043C\u043E \u0437\u0430 \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u043B."
