  npcName: "\u0421\u043A\u043B\u0430\u0434\u043E\u0432 \u0440\u0430\u0431\u043E\u0442\u043D\u0438\u043A"
  dialogueLines:
  - "\u0422\u043E\u0437\u0438 \u043C\u0430\u0433\u0430\u0437\u0438\u043D \u0435 \u0441\u0430\u043C\u043E
