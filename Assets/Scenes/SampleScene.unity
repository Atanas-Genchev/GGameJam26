      \u043A\u043E\u0448\u0447\u0435 \u0437\u0430 \u0431\u043E\u043A\u043B\u0443\u043A."
  - speakerNPC: 2
    text: "\u041F\u0440\u0438 \u043C\u0435\u043D \u0438\u0434\u0432\u0430\u0442 \u0432\u0441\u044F\u043A\u0430\u043A\u0432\u0438
      \u043C\u044A\u0436\u0435\u2026 \u043A\u0440\u0430\u0441\u0438\u0432\u0438,
      \u0433\u0440\u043E\u0437\u043D\u0438, \u043C\u043B\u0430\u0434\u0438, \u0441\u0442\u0430\u0440\u0438\u2026"
  - speakerNPC: 1
    text: "\u0412\u0441\u0435 \u043C\u0438 \u0435 \u0442\u0430\u044F, \u0449\u043E\u043C
      \u043F\u043B\u0430\u0449\u0430\u0442."
  - speakerNPC: 2
    text: "\u0412\u0441\u0435\u043A\u0438 \u0445\u0432\u044A\u0440\u043B\u044F \u043F\u043E
      \u043D\u0435\u0449\u043E \u043F\u0440\u0438 \u043C\u0435\u043D, \u0431\u0435\u2026
      \u0412\u0441\u0435 \u0435\u0434\u043D\u043E \u0441\u044A\u043C \u043A\u043E\u0444\u0430."
  - speakerNPC: 1
    text: "\u0417\u0430\u0434\u0440\u044A\u0436\u043A\u0438 \u0438 \u0432\u0440\u044A\u0437\u043A\u0438\u2026
      \u0438 \u0434\u0440\u0435\u0445\u0438, \u0447\u0430\u0442-\u043F\u0430\u0442
      \u0445\u0430\u043B\u043A\u0438\u2026 \u0438 \u043F\u043E\u0441\u043B\u0435
      \u043E\u0431\u0440\u0430\u0442\u043D\u043E \u043F\u0440\u0438 \u0436\u0435\u043D\u0438\u0442\u0435
      \u0441\u0438."
  - speakerNPC: 2
    text: "\u041F\u0440\u0435\u0434\u0438 \u0433\u0438 \u043F\u0430\u0437\u0435\u0445
      \u0442\u0438\u044F \u0431\u043E\u043A\u043B\u0443\u0446\u0438, \u043A\u043E\u043B\u043A\u043E
      \u0441\u044A\u043C \u0431\u0438\u043B\u0430 \u0442\u044A\u043F\u0430\u2026
      \u041C\u0438\u0441\u043B\u0435\u0445, \u0447\u0435 \u0437\u043D\u0430\u0447\u0430\u0442
      \u043D\u0435\u0449\u043E."
  - speakerNPC: 1
    text: "\u0421\u0435\u0433\u0430 \u043F\u0430\u0437\u044F \u0441\u0430\u043C\u043E
      \u043F\u0430\u0440\u0438\u0442\u0435. \u0414\u0440\u0443\u0433\u043E\u0442\u043E
      \u0434\u0430 \u0433\u043D\u0438\u0435. \u041D\u0435 \u043C\u0438 \u043F\u0443\u043A\u0430."
  - speakerNPC: 2
    text: "\u0411\u043E\u043A\u043B\u0443\u0446\u0438, \u043A\u0430\u0437\u0432\u0430\u043C
      \u0442\u0438\u2026 \u0438 \u0432\u0435\u0449\u0438\u0442\u0435, \u0438 \u043C\u044A\u0436\u0435\u0442\u0435   "
  speechBubblePrefab: {fileID: 5849868092928771901, guid: c8f34332b3d0c4851b84453f34e91b69, type: 3}
  bubbleOffset: {x: 0, y: 2.5, z: 0}
